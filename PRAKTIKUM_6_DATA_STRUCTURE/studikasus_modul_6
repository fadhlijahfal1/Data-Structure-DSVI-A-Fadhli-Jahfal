# ─────────────────────────────────────────────
# SESSION STATE INIT
# ─────────────────────────────────────────────
def init_state(key, default):
    if key not in st.session_state:
        st.session_state[key] = default

# Kasus 1 - Bank
init_state("bank_queue", deque())
init_state("bank_served", [])
init_state("bank_counter", 1)

# Kasus 2 - Mahasiswa
init_state("mhs_queue", deque())
init_state("mhs_served", [])
init_state("mhs_counter", 1)

# Kasus 3 - Printer
init_state("printer_queue", deque())
init_state("printer_done", [])
init_state("printer_counter", 1)

# Kasus 4 - Call Center
init_state("cc_queue", deque())
init_state("cc_served", [])
init_state("cc_counter", 1)

# Kasus 5 - Buffer Video
init_state("video_buffer", deque())
init_state("video_played", [])
init_state("video_counter", 1)

# Kasus 6 - Tiket Kereta
init_state("ticket_queue", deque())
init_state("ticket_done", [])
init_state("ticket_counter", 1)

# ─────────────────────────────────────────────
st.markdown('<div class="main-title">🗂️ Sistem Antrian Queue — 6 Studi Kasus</div>', unsafe_allow_html=True)
st.markdown("---")

tabs = st.tabs([
    "🏦 Antrian Bank",
    "🎓 Pendaftaran Mahasiswa",
    "🖨️ Printer Queue",
    "📞 Call Center",
